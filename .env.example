# 微信AI自动回复 - 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# AI API配置
WECHAT_AI_API_URL=http://your-api-url/v1
WECHAT_AI_API_KEY=your-api-key
WECHAT_AI_MODEL=your-model-name

# 代理配置（科学上网代理，不需要可留空）
WECHAT_PROXY_URL=http://127.0.0.1:10808

# AI生图API密钥
IMAGE_GEN_API_KEY=02118e9df8b73702a2a19e3b6d364319ad3329323acc610c1977dffe201e4dce

# 我的微信昵称（群聊中只有被@时才回复）
WECHAT_MY_NICKNAME=你的微信昵称
